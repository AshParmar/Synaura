# .env.example
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.

# ── LLM APIs ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Vector Database (Pinecone) ────────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_pinecone_environment_here   # e.g. us-east-1-aws
PINECONE_INDEX_NAME=synaura-radiology

# ── Application Database (MongoDB Atlas) ──────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/synaura?retryWrites=true&w=majority

# ── Google Cloud Platform ─────────────────────────────────────────────────────
GCP_PROJECT_ID=your_gcp_project_id
GCS_BUCKET_NAME=synaura-uploads
GCS_FAISS_BUCKET=synaura-uploads   # same bucket is fine, index stored under faiss_index/
# Path to your GCP service account key JSON (for local dev only)
GOOGLE_APPLICATION_CREDENTIALS=./cloud/service-account-key.json
# Cloud Run backend URL (set this in Vercel env vars for production)
NEXT_PUBLIC_BACKEND_URL=https://synaura-backend-xxxx-uc.a.run.app

# ── Authentication (Clerk) ────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/demo
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/demo

# ── Monitoring (Sentry) ───────────────────────────────────────────────────────
SENTRY_DSN=https://xxxxxxxxxxxx@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxx@o0.ingest.sentry.io/0
